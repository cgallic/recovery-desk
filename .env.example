# Copy to .env. Everything runs OFFLINE with no key (deterministic fallback),
# so the demo and tests pass on a clean clone with this file empty.

# Optional: set to run the live Claude planner / grader / reviser (the engine's
# inner loop) AND the /api/agent autonomous tool-driving loop (Anthropic preferred).
ANTHROPIC_API_KEY=

# Optional: model key for the /api/agent autonomous loop when ANTHROPIC_API_KEY is
# unset. The real model selects + sequences the engine ops (build/score/run/book)
# as tools. temperature 0, maxOutputTokens 512, <=6 tool turns. Cap spend on the key.
GEMINI_API_KEY=

# Optional overrides.
RECOVERY_DESK_MODEL=claude-sonnet-4-5
AGENT_MODEL=claude-haiku-4-5
GEMINI_MODEL=gemini-2.5-flash
RUBRIC=rubrics/bookability.rubric.yaml
FIXTURE=fixtures/missed_call.json
PORT=8799
