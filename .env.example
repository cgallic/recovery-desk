# Copy to .env. Everything runs OFFLINE with no key (deterministic fallback),
# so the demo and tests pass on a clean clone with this file empty.

# Optional: set to run the live Claude planner / grader / reviser.
ANTHROPIC_API_KEY=

# Optional overrides.
RECOVERY_DESK_MODEL=claude-sonnet-4-5
RUBRIC=rubrics/bookability.rubric.yaml
FIXTURE=fixtures/missed_call.json
PORT=8799
